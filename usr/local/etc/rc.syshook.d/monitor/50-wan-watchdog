#!/bin/sh
#===============================================================================
# OPNsense multi-WAN recovery watchdog
#-------------------------------------------------------------------------------
# Purpose
#   React to OPNsense gateway-monitor events for one or more configured gateways.
#   When a configured gateway is currently in the exact state "down", run:
#
#       configctl interface reconfigure <interface>
#
#   once per minute until that gateway is no longer exactly "down".
#
# Verified dependencies used by this script
#   1. OPNsense rc.syshook monitor hook:
#      - /usr/local/etc/rc.syshook.d/monitor/
#      - first argument is a comma-separated list of affected gateway names
#
#   2. Gateway status command:
#      - pluginctl -r return_gateways_status
#      - verified by user output to return JSON with:
#          {
#            "dpinger": {
#              "<gateway-name>": {
#                "status": "none|down|force_down|..."
#              }
#            }
#          }
#
#   3. Recovery command:
#      - configctl interface reconfigure <interface>
#
# Multi-WAN design
#   - A mapping table defines which gateway name corresponds to which OPNsense
#     interface token.
#   - Each interface has its own lock directory and state cache.
#   - Multiple recovery loops may run at once, one per mapped interface.
#
# Operational behavior
#   - The script does nothing until OPNsense monitor infrastructure invokes it.
#   - For each affected gateway that is configured in the mapping table:
#       * exact "down"       => start/continue recovery loop
#       * exact "force_down" => ignore
#       * exact "none"       => healthy / do nothing
#       * anything else      => log and do nothing
#
# Security and maintenance notes
#   - Runs as root from OPNsense syshook.
#   - Uses fixed command paths and a restrictive umask.
#   - Uses atomic lock directories so duplicate monitor events cannot create
#     concurrent recovery loops for the same interface.
#   - Never executes untrusted input as shell code.
#   - Logs to syslog using a dedicated tag for auditability.
#===============================================================================

set -eu
umask 077

#-------------------------------------------------------------------------------
# Configuration
#-------------------------------------------------------------------------------
# Mapping table: one entry per line, formatted as:
#   <gateway-name>:<interface-token>
#
# Examples:
#   WAN1_GW:wan
#   WAN2_GW:wan2
#   WAN3_GW:wan3
#
# Add or remove lines as needed.
GATEWAY_INTERFACE_MAP='
WAN1_GW:wan
WAN2_GW:wan2
'

# Retry interval while a gateway remains exactly "down".
RETRY_INTERVAL_SECONDS=60

# Small settle period after a reconfigure request.
POST_RECONFIGURE_SETTLE_SECONDS=10

# Safety ceiling for one continuous retry loop per interface.
MAX_ATTEMPTS=60

# Runtime files and directories.
STATE_DIR="/var/run/opnsense-wan-watchdog"
LOG_TAG="wan-watchdog"

# Fixed command paths.
LOGGER="/usr/bin/logger"
MKDIR="/bin/mkdir"
RMDIR="/bin/rmdir"
DATE="/bin/date"
SLEEP="/bin/sleep"
PLUGINCTL="/usr/local/sbin/pluginctl"
CONFIGCTL="/usr/local/sbin/configctl"
PYTHON3="/usr/local/bin/python3"

#-------------------------------------------------------------------------------
# Logging helper
#-------------------------------------------------------------------------------
log_msg() {
    "${LOGGER}" -t "${LOG_TAG}" -- "$*"
}

#-------------------------------------------------------------------------------
# Ensure runtime directory exists.
#-------------------------------------------------------------------------------
prepare_runtime() {
    if [ ! -d "${STATE_DIR}" ]; then
        "${MKDIR}" -p "${STATE_DIR}"
        chmod 700 "${STATE_DIR}"
    fi
}

#-------------------------------------------------------------------------------
# Look up the interface token for a gateway name.
#-------------------------------------------------------------------------------
# Returns the interface token on stdout if found, otherwise returns failure.
#-------------------------------------------------------------------------------
gateway_to_interface() {
    target_gateway="$1"

    printf '%s\n' "${GATEWAY_INTERFACE_MAP}" | while IFS=: read -r gw ifname; do
        [ -n "${gw}" ] || continue
        if [ "${gw}" = "${target_gateway}" ]; then
            printf '%s\n' "${ifname}"
            exit 0
        fi
    done
}

#-------------------------------------------------------------------------------
# Query current gateway status from pluginctl.
#-------------------------------------------------------------------------------
# Reads:
#   .dpinger[GATEWAY_NAME].status
#
# Returns one of:
#   down        - exact failure state that should trigger recovery
#   force_down  - administratively forced down; explicitly ignored
#   none        - healthy / recovered state
#   other       - any other non-empty status string
#   unknown     - JSON missing, malformed, or gateway not found
#
# Only exact "down" causes recovery attempts.
#-------------------------------------------------------------------------------
get_gateway_status() {
    target_gateway="$1"

    "${PLUGINCTL}" -r return_gateways_status 2>/dev/null | "${PYTHON3}" -c '
import json
import sys

target = sys.argv[1]

try:
    data = json.load(sys.stdin)
except Exception:
    print("unknown")
    raise SystemExit(0)

status = "unknown"

dp = data.get("dpinger")
if isinstance(dp, dict):
    gw = dp.get(target)
    if isinstance(gw, dict):
        raw = gw.get("status")
        if raw is not None:
            raw = str(raw).strip().lower()
            if raw == "down":
                status = "down"
            elif raw == "force_down":
                status = "force_down"
            elif raw == "none":
                status = "none"
            elif raw:
                status = "other"

print(status)
' "${target_gateway}"
}

#-------------------------------------------------------------------------------
# Persist last observed state for debugging.
#-------------------------------------------------------------------------------
write_status_cache() {
    gateway_name="$1"
    current_status="$2"
    status_cache="${STATE_DIR}/${gateway_name}.status"

    printf '%s %s\n' "$("${DATE}" -Iseconds)" "${current_status}" > "${status_cache}"
}

#-------------------------------------------------------------------------------
# Execute the requested recovery action.
#-------------------------------------------------------------------------------
reconfigure_interface() {
    gateway_name="$1"
    interface_name="$2"

    log_msg "gateway=${gateway_name} interface=${interface_name} action=reconfigure"
    "${CONFIGCTL}" interface reconfigure "${interface_name}"
}

#-------------------------------------------------------------------------------
# Lock cleanup helper.
#-------------------------------------------------------------------------------
cleanup_lock() {
    lock_dir="$1"
    "${RMDIR}" "${lock_dir}" 2>/dev/null || true
}

#-------------------------------------------------------------------------------
# Recovery loop for one gateway/interface pair.
#-------------------------------------------------------------------------------
# Uses an atomic lock directory so duplicate monitor events cannot create
# concurrent retry loops for the same interface.
#-------------------------------------------------------------------------------
run_recovery_loop() {
    gateway_name="$1"
    interface_name="$2"

    lock_dir="/tmp/opnsense-wan-watchdog.${interface_name}.lock.d"

    if ! "${MKDIR}" "${lock_dir}" 2>/dev/null; then
        log_msg "gateway=${gateway_name} interface=${interface_name} action=skip reason=loop_already_active"
        return 0
    fi

    trap 'cleanup_lock "${lock_dir}"' EXIT INT TERM HUP

    attempt=0

    while :; do
        current_status="$(get_gateway_status "${gateway_name}")"
        write_status_cache "${gateway_name}" "${current_status}"

        if [ "${current_status}" != "down" ]; then
            log_msg "gateway=${gateway_name} interface=${interface_name} action=stop reason=status_changed status=${current_status}"
            return 0
        fi

        attempt=$((attempt + 1))
        log_msg "gateway=${gateway_name} interface=${interface_name} action=recover attempt=${attempt}/${MAX_ATTEMPTS} status=down"

        reconfigure_interface "${gateway_name}" "${interface_name}"
        "${SLEEP}" "${POST_RECONFIGURE_SETTLE_SECONDS}"

        if [ "${attempt}" -ge "${MAX_ATTEMPTS}" ]; then
            log_msg "gateway=${gateway_name} interface=${interface_name} action=stop reason=max_attempts_reached"
            return 0
        fi

        "${SLEEP}" "${RETRY_INTERVAL_SECONDS}"
    done
}

#-------------------------------------------------------------------------------
# Handle one gateway from the monitor event.
#-------------------------------------------------------------------------------
handle_gateway_event() {
    gateway_name="$1"

    interface_name="$(gateway_to_interface "${gateway_name}" || true)"

    if [ -z "${interface_name}" ]; then
        # Ignore gateways that are not explicitly configured in the mapping.
        log_msg "gateway=${gateway_name} action=ignore reason=not_mapped"
        return 0
    fi

    current_status="$(get_gateway_status "${gateway_name}")"
    write_status_cache "${gateway_name}" "${current_status}"

    case "${current_status}" in
        down)
            log_msg "gateway=${gateway_name} interface=${interface_name} action=start reason=down"
            run_recovery_loop "${gateway_name}" "${interface_name}"
            ;;
        force_down)
            log_msg "gateway=${gateway_name} interface=${interface_name} action=ignore reason=force_down"
            ;;
        none)
            log_msg "gateway=${gateway_name} interface=${interface_name} action=ignore reason=healthy status=none"
            ;;
        other)
            log_msg "gateway=${gateway_name} interface=${interface_name} action=ignore reason=non_down_status"
            ;;
        unknown)
            log_msg "gateway=${gateway_name} interface=${interface_name} action=ignore reason=status_unknown"
            ;;
        *)
            log_msg "gateway=${gateway_name} interface=${interface_name} action=ignore reason=unexpected_parser_result status=${current_status}"
            ;;
    esac
}

#-------------------------------------------------------------------------------
# Main entry point.
#-------------------------------------------------------------------------------
main() {
    prepare_runtime

    affected_gateways="${1:-}"
    [ -n "${affected_gateways}" ] || exit 0

    old_ifs=${IFS}
    IFS=,
    set -- ${affected_gateways}
    IFS=${old_ifs}

    for gateway_name in "$@"; do
        [ -n "${gateway_name}" ] || continue
        handle_gateway_event "${gateway_name}"
    done
}

main "$@"
