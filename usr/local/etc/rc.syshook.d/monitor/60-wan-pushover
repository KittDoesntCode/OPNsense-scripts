#!/bin/sh
#===============================================================================
# OPNsense gateway state -> Pushover notifier
#-------------------------------------------------------------------------------
# Purpose
#   Send a Pushover notification when a gateway passed by the OPNsense
#   monitor syshook changes state according to:
#
#       pluginctl -r return_gateways_status
#
# Behavior
#   - Processes only gateway names passed in argument 1 by the monitor syshook.
#   - Reads current status from pluginctl JSON.
#   - Sends an alert only when the status changes.
#   - Suppresses duplicate alerts.
#   - Uses the gateway name in the alert.
#   - Includes old status and new status in the alert.
#   - Handles any non-empty status string, including:
#       none, down, force_down, unknown, etc.
#
# First observation behavior
#   - If no previous cached state exists:
#       * current status = none       -> store baseline, no alert
#       * current status != none      -> store state and send alert immediately
#
# Security notes
#   - This script contains secrets. Keep it mode 700 or 600.
#   - Uses HTTPS with TLS verification enabled by curl by default.
#   - Uses fixed command paths.
#   - No eval, no dynamic shell code, no untrusted command execution.
#===============================================================================

set -eu
umask 077

#-------------------------------------------------------------------------------
# Pushover configuration
#-------------------------------------------------------------------------------
APP_TOKEN="REPLACE_WITH_YOUR_PUSHOVER_APP_TOKEN"
USER_KEY="REPLACE_WITH_YOUR_PUSHOVER_USER_OR_GROUP_KEY"

DEVICE_NAME=""
PUSHOVER_PRIORITY="0"
PUSHOVER_SOUND=""
PUSHOVER_TITLE_PREFIX="OPNsense Gateway Alert"

#-------------------------------------------------------------------------------
# Runtime and command paths
#-------------------------------------------------------------------------------
STATE_DIR="/var/run/opnsense-wan-pushover"
LOG_TAG="wan-pushover"
PUSHOVER_API_URL="https://api.pushover.net/1/messages.json"

LOGGER="/usr/bin/logger"
MKDIR="/bin/mkdir"
CAT="/bin/cat"
MV="/bin/mv"
RM="/bin/rm"
PLUGINCTL="/usr/local/sbin/pluginctl"
PYTHON3="/usr/local/bin/python3"
CURL="/usr/local/bin/curl"

#-------------------------------------------------------------------------------
# Logging helper
#-------------------------------------------------------------------------------
log_msg() {
    "${LOGGER}" -t "${LOG_TAG}" -- "$*"
}

#-------------------------------------------------------------------------------
# Prepare runtime directory with restrictive permissions
#-------------------------------------------------------------------------------
prepare_runtime() {
    if [ ! -d "${STATE_DIR}" ]; then
        "${MKDIR}" -p "${STATE_DIR}"
        chmod 700 "${STATE_DIR}"
    fi
}

#-------------------------------------------------------------------------------
# Validate configuration
#-------------------------------------------------------------------------------
validate_config() {
    case "${APP_TOKEN}" in
        ""|REPLACE_WITH_*)
            log_msg "configuration error: APP_TOKEN is not set"
            exit 1
            ;;
    esac

    case "${USER_KEY}" in
        ""|REPLACE_WITH_*)
            log_msg "configuration error: USER_KEY is not set"
            exit 1
            ;;
    esac
}

#-------------------------------------------------------------------------------
# Convert raw OPNsense status into human-friendly alert wording
#-------------------------------------------------------------------------------
format_status_for_alert() {
    raw_status="$1"

    case "${raw_status}" in
        none)
            printf '%s\n' "up"
            ;;
        down)
            printf '%s\n' "down"
            ;;
        force_down)
            printf '%s\n' "forced down"
            ;;
        unknown)
            printf '%s\n' "unknown"
            ;;
        *)
            printf '%s\n' "${raw_status}"
            ;;
    esac
}

#-------------------------------------------------------------------------------
# Read one gateway status from pluginctl JSON
#-------------------------------------------------------------------------------
get_gateway_status() {
    target_gateway="$1"

    "${PLUGINCTL}" -r return_gateways_status 2>/dev/null | "${PYTHON3}" -c '
import json
import sys

target = sys.argv[1]

try:
    data = json.load(sys.stdin)
except Exception:
    print("unknown")
    raise SystemExit(0)

status = "unknown"
dp = data.get("dpinger")

if isinstance(dp, dict):
    gw = dp.get(target)
    if isinstance(gw, dict):
        raw = gw.get("status")
        if raw is not None:
            raw = str(raw).strip().lower()
            if raw:
                status = raw

print(status)
' "${target_gateway}"
}

#-------------------------------------------------------------------------------
# Read cached last-known status for one gateway
#-------------------------------------------------------------------------------
get_last_status() {
    gateway_name="$1"
    state_file="${STATE_DIR}/${gateway_name}.last"

    if [ -f "${state_file}" ]; then
        "${CAT}" "${state_file}"
    else
        printf '%s\n' ""
    fi
}

#-------------------------------------------------------------------------------
# Save cached last-known status atomically
#-------------------------------------------------------------------------------
set_last_status() {
    gateway_name="$1"
    new_status="$2"

    state_file="${STATE_DIR}/${gateway_name}.last"
    temp_file="${STATE_DIR}/${gateway_name}.last.tmp.$$"

    printf '%s\n' "${new_status}" > "${temp_file}"
    "${MV}" "${temp_file}" "${state_file}"
}

#-------------------------------------------------------------------------------
# Send one Pushover message using curl
#-------------------------------------------------------------------------------
send_pushover_message() {
    title="$1"
    message="$2"

    response_file="${STATE_DIR}/pushover-response.$$"

    if [ -n "${DEVICE_NAME}" ] && [ -n "${PUSHOVER_SOUND}" ]; then
        if ! "${CURL}" \
            --silent \
            --show-error \
            --fail \
            --request POST \
            --output "${response_file}" \
            --data-urlencode "token=${APP_TOKEN}" \
            --data-urlencode "user=${USER_KEY}" \
            --data-urlencode "title=${title}" \
            --data-urlencode "message=${message}" \
            --data-urlencode "priority=${PUSHOVER_PRIORITY}" \
            --data-urlencode "device=${DEVICE_NAME}" \
            --data-urlencode "sound=${PUSHOVER_SOUND}" \
            "${PUSHOVER_API_URL}" >/dev/null 2>&1; then
            log_msg "action=notify result=transport_error"
            "${RM}" -f "${response_file}"
            return 1
        fi
    elif [ -n "${DEVICE_NAME}" ]; then
        if ! "${CURL}" \
            --silent \
            --show-error \
            --fail \
            --request POST \
            --output "${response_file}" \
            --data-urlencode "token=${APP_TOKEN}" \
            --data-urlencode "user=${USER_KEY}" \
            --data-urlencode "title=${title}" \
            --data-urlencode "message=${message}" \
            --data-urlencode "priority=${PUSHOVER_PRIORITY}" \
            --data-urlencode "device=${DEVICE_NAME}" \
            "${PUSHOVER_API_URL}" >/dev/null 2>&1; then
            log_msg "action=notify result=transport_error"
            "${RM}" -f "${response_file}"
            return 1
        fi
    elif [ -n "${PUSHOVER_SOUND}" ]; then
        if ! "${CURL}" \
            --silent \
            --show-error \
            --fail \
            --request POST \
            --output "${response_file}" \
            --data-urlencode "token=${APP_TOKEN}" \
            --data-urlencode "user=${USER_KEY}" \
            --data-urlencode "title=${title}" \
            --data-urlencode "message=${message}" \
            --data-urlencode "priority=${PUSHOVER_PRIORITY}" \
            --data-urlencode "sound=${PUSHOVER_SOUND}" \
            "${PUSHOVER_API_URL}" >/dev/null 2>&1; then
            log_msg "action=notify result=transport_error"
            "${RM}" -f "${response_file}"
            return 1
        fi
    else
        if ! "${CURL}" \
            --silent \
            --show-error \
            --fail \
            --request POST \
            --output "${response_file}" \
            --data-urlencode "token=${APP_TOKEN}" \
            --data-urlencode "user=${USER_KEY}" \
            --data-urlencode "title=${title}" \
            --data-urlencode "message=${message}" \
            --data-urlencode "priority=${PUSHOVER_PRIORITY}" \
            "${PUSHOVER_API_URL}" >/dev/null 2>&1; then
            log_msg "action=notify result=transport_error"
            "${RM}" -f "${response_file}"
            return 1
        fi
    fi

    api_status="$("${PYTHON3}" -c '
import json
import sys
try:
    with open(sys.argv[1], "r", encoding="utf-8") as fh:
        data = json.load(fh)
    print(str(data.get("status", "")))
except Exception:
    print("")
' "${response_file}")"

    request_id="$("${PYTHON3}" -c '
import json
import sys
try:
    with open(sys.argv[1], "r", encoding="utf-8") as fh:
        data = json.load(fh)
    print(str(data.get("request", "")))
except Exception:
    print("")
' "${response_file}")"

    if [ "${api_status}" = "1" ]; then
        log_msg "action=notify result=success request=${request_id}"
        "${RM}" -f "${response_file}"
        return 0
    fi

    error_summary="$("${PYTHON3}" -c '
import json
import sys
try:
    with open(sys.argv[1], "r", encoding="utf-8") as fh:
        data = json.load(fh)
    errs = data.get("errors", [])
    if isinstance(errs, list):
        print("; ".join(str(x) for x in errs))
    else:
        print(str(errs))
except Exception:
    print("unable to parse pushover error response")
' "${response_file}")"

    log_msg "action=notify result=api_error request=${request_id} errors=${error_summary}"
    "${RM}" -f "${response_file}"
    return 1
}

#-------------------------------------------------------------------------------
# Build and send one transition alert
#-------------------------------------------------------------------------------
notify_status_change() {
    gateway_name="$1"
    old_status="$2"
    new_status="$3"

    old_status_text="$(format_status_for_alert "${old_status}")"
    new_status_text="$(format_status_for_alert "${new_status}")"

    title="${PUSHOVER_TITLE_PREFIX}: ${gateway_name}"
    message="Gateway ${gateway_name} changed status from ${old_status_text} to ${new_status_text} on OPNsense."

    send_pushover_message "${title}" "${message}"
}

#-------------------------------------------------------------------------------
# Build and send one first-seen not-up alert
#-------------------------------------------------------------------------------
notify_first_problem_state() {
    gateway_name="$1"
    current_status="$2"

    current_status_text="$(format_status_for_alert "${current_status}")"

    title="${PUSHOVER_TITLE_PREFIX}: ${gateway_name}"
    message="Gateway ${gateway_name} is ${current_status_text} on first observation on OPNsense."

    send_pushover_message "${title}" "${message}"
}

#-------------------------------------------------------------------------------
# Process one gateway named by the monitor syshook event
#-------------------------------------------------------------------------------
handle_gateway_event() {
    gateway_name="$1"

    current_status="$(get_gateway_status "${gateway_name}")"
    last_status="$(get_last_status "${gateway_name}")"

    log_msg "gateway=${gateway_name} action=observed current_status=${current_status} last_status=${last_status:-none_cached}"

    # No cached state exists yet.
    # If current state is healthy (none), seed baseline only.
    # If current state is anything else, seed state and alert immediately.
    if [ -z "${last_status}" ]; then
        set_last_status "${gateway_name}" "${current_status}"

        if [ "${current_status}" = "none" ]; then
            log_msg "gateway=${gateway_name} action=baseline status=${current_status}"
        else
            log_msg "gateway=${gateway_name} action=alert reason=first_observation status=${current_status}"
            notify_first_problem_state "${gateway_name}" "${current_status}" || true
        fi
        return 0
    fi

    # Duplicate status => no alert.
    if [ "${current_status}" = "${last_status}" ]; then
        log_msg "gateway=${gateway_name} action=ignore reason=no_change status=${current_status}"
        return 0
    fi

    # Status changed => persist and alert.
    set_last_status "${gateway_name}" "${current_status}"
    log_msg "gateway=${gateway_name} action=alert transition=${last_status}->${current_status}"
    notify_status_change "${gateway_name}" "${last_status}" "${current_status}" || true
}

#-------------------------------------------------------------------------------
# Main entry point
#-------------------------------------------------------------------------------
main() {
    prepare_runtime
    validate_config

    affected_gateways="${1:-}"
    log_msg "action=start raw_arg=${affected_gateways:-empty}"

    [ -n "${affected_gateways}" ] || exit 0

    old_ifs=${IFS}
    IFS=,
    set -- ${affected_gateways}
    IFS=${old_ifs}

    for gateway_name in "$@"; do
        [ -n "${gateway_name}" ] || continue
        handle_gateway_event "${gateway_name}"
    done
}

main "$@"
