#!/bin/sh
#===============================================================================
# OPNsense gateway -> Pushover delayed boot check
#-------------------------------------------------------------------------------
# Purpose
#   After OPNsense network startup, wait a short stabilization period and then
#   inspect all gateways returned by:
#
#       pluginctl -r return_gateways_status
#
#   If a gateway is still not up after boot, send one alert and seed the same
#   state cache used by 60-wan-pushover.
#
# Why this exists
#   The monitor syshook handles state transitions. If a gateway is already not
#   up during boot and never transitions afterward, the monitor notifier may
#   not produce an alert. This script fills that gap with a one-time delayed
#   post-boot check.
#
# Behavior
#   - Wait BOOT_DELAY_SECONDS after startup.
#   - Query all gateways from pluginctl JSON.
#   - For each gateway:
#       * none       -> healthy, no alert
#       * anything else -> send alert
#   - Always update the shared cache in /var/run/opnsense-wan-pushover/
#   - Do not send duplicate alerts if the shared cache already contains the same
#     status, which can happen if the monitor script has already run.
#
# Security notes
#   - This script contains secrets. Keep it mode 700 or 600.
#   - Uses HTTPS with TLS verification enabled by curl by default.
#   - Uses fixed command paths.
#   - No eval, no dynamic shell code, no untrusted command execution.
#===============================================================================

set -eu
umask 077

#-------------------------------------------------------------------------------
# Pushover configuration
#-------------------------------------------------------------------------------
APP_TOKEN="REPLACE_WITH_YOUR_PUSHOVER_APP_TOKEN"
USER_KEY="REPLACE_WITH_YOUR_PUSHOVER_USER_OR_GROUP_KEY"

DEVICE_NAME=""
PUSHOVER_PRIORITY="0"
PUSHOVER_SOUND=""
PUSHOVER_TITLE_PREFIX="OPNsense Gateway Alert"

BOOT_DELAY_SECONDS="90"

#-------------------------------------------------------------------------------
# Runtime and command paths
#-------------------------------------------------------------------------------
STATE_DIR="/var/run/opnsense-wan-pushover"
LOG_TAG="wan-pushover-bootcheck"
PUSHOVER_API_URL="https://api.pushover.net/1/messages.json"

LOGGER="/usr/bin/logger"
MKDIR="/bin/mkdir"
CAT="/bin/cat"
MV="/bin/mv"
RM="/bin/rm"
SLEEP="/bin/sleep"
PLUGINCTL="/usr/local/sbin/pluginctl"
PYTHON3="/usr/local/bin/python3"
CURL="/usr/local/bin/curl"

#-------------------------------------------------------------------------------
# Logging helper
#-------------------------------------------------------------------------------
log_msg() {
    "${LOGGER}" -t "${LOG_TAG}" -- "$*"
}

#-------------------------------------------------------------------------------
# Prepare runtime directory with restrictive permissions
#-------------------------------------------------------------------------------
prepare_runtime() {
    if [ ! -d "${STATE_DIR}" ]; then
        "${MKDIR}" -p "${STATE_DIR}"
        chmod 700 "${STATE_DIR}"
    fi
}

#-------------------------------------------------------------------------------
# Validate configuration
#-------------------------------------------------------------------------------
validate_config() {
    case "${APP_TOKEN}" in
        ""|REPLACE_WITH_*)
            log_msg "configuration error: APP_TOKEN is not set"
            exit 1
            ;;
    esac

    case "${USER_KEY}" in
        ""|REPLACE_WITH_*)
            log_msg "configuration error: USER_KEY is not set"
            exit 1
            ;;
    esac
}

#-------------------------------------------------------------------------------
# Convert raw OPNsense status into human-friendly alert wording
#-------------------------------------------------------------------------------
format_status_for_alert() {
    raw_status="$1"

    case "${raw_status}" in
        none)
            printf '%s\n' "up"
            ;;
        down)
            printf '%s\n' "down"
            ;;
        force_down)
            printf '%s\n' "forced down"
            ;;
        unknown)
            printf '%s\n' "unknown"
            ;;
        *)
            printf '%s\n' "${raw_status}"
            ;;
    esac
}

#-------------------------------------------------------------------------------
# Read all gateway statuses from pluginctl JSON
#-------------------------------------------------------------------------------
# Output format:
#   gateway_name<TAB>status
#-------------------------------------------------------------------------------
list_gateway_statuses() {
    "${PLUGINCTL}" -r return_gateways_status 2>/dev/null | "${PYTHON3}" -c '
import json
import sys

try:
    data = json.load(sys.stdin)
except Exception:
    raise SystemExit(0)

dp = data.get("dpinger")
if not isinstance(dp, dict):
    raise SystemExit(0)

for gateway_name, value in dp.items():
    status = "unknown"
    if isinstance(value, dict):
        raw = value.get("status")
        if raw is not None:
            raw = str(raw).strip().lower()
            if raw:
                status = raw
    print(f"{gateway_name}\t{status}")
'
}

#-------------------------------------------------------------------------------
# Read cached last-known status for one gateway
#-------------------------------------------------------------------------------
get_last_status() {
    gateway_name="$1"
    state_file="${STATE_DIR}/${gateway_name}.last"

    if [ -f "${state_file}" ]; then
        "${CAT}" "${state_file}"
    else
        printf '%s\n' ""
    fi
}

#-------------------------------------------------------------------------------
# Save cached last-known status atomically
#-------------------------------------------------------------------------------
set_last_status() {
    gateway_name="$1"
    new_status="$2"

    state_file="${STATE_DIR}/${gateway_name}.last"
    temp_file="${STATE_DIR}/${gateway_name}.last.tmp.$$"

    printf '%s\n' "${new_status}" > "${temp_file}"
    "${MV}" "${temp_file}" "${state_file}"
}

#-------------------------------------------------------------------------------
# Send one Pushover message using curl
#-------------------------------------------------------------------------------
send_pushover_message() {
    title="$1"
    message="$2"

    response_file="${STATE_DIR}/pushover-boot-response.$$"

    if [ -n "${DEVICE_NAME}" ] && [ -n "${PUSHOVER_SOUND}" ]; then
        if ! "${CURL}" \
            --silent \
            --show-error \
            --fail \
            --request POST \
            --output "${response_file}" \
            --data-urlencode "token=${APP_TOKEN}" \
            --data-urlencode "user=${USER_KEY}" \
            --data-urlencode "title=${title}" \
            --data-urlencode "message=${message}" \
            --data-urlencode "priority=${PUSHOVER_PRIORITY}" \
            --data-urlencode "device=${DEVICE_NAME}" \
            --data-urlencode "sound=${PUSHOVER_SOUND}" \
            "${PUSHOVER_API_URL}" >/dev/null 2>&1; then
            log_msg "action=notify result=transport_error"
            "${RM}" -f "${response_file}"
            return 1
        fi
    elif [ -n "${DEVICE_NAME}" ]; then
        if ! "${CURL}" \
            --silent \
            --show-error \
            --fail \
            --request POST \
            --output "${response_file}" \
            --data-urlencode "token=${APP_TOKEN}" \
            --data-urlencode "user=${USER_KEY}" \
            --data-urlencode "title=${title}" \
            --data-urlencode "message=${message}" \
            --data-urlencode "priority=${PUSHOVER_PRIORITY}" \
            --data-urlencode "device=${DEVICE_NAME}" \
            "${PUSHOVER_API_URL}" >/dev/null 2>&1; then
            log_msg "action=notify result=transport_error"
            "${RM}" -f "${response_file}"
            return 1
        fi
    elif [ -n "${PUSHOVER_SOUND}" ]; then
        if ! "${CURL}" \
            --silent \
            --show-error \
            --fail \
            --request POST \
            --output "${response_file}" \
            --data-urlencode "token=${APP_TOKEN}" \
            --data-urlencode "user=${USER_KEY}" \
            --data-urlencode "title=${title}" \
            --data-urlencode "message=${message}" \
            --data-urlencode "priority=${PUSHOVER_PRIORITY}" \
            --data-urlencode "sound=${PUSHOVER_SOUND}" \
            "${PUSHOVER_API_URL}" >/dev/null 2>&1; then
            log_msg "action=notify result=transport_error"
            "${RM}" -f "${response_file}"
            return 1
        fi
    else
        if ! "${CURL}" \
            --silent \
            --show-error \
            --fail \
            --request POST \
            --output "${response_file}" \
            --data-urlencode "token=${APP_TOKEN}" \
            --data-urlencode "user=${USER_KEY}" \
            --data-urlencode "title=${title}" \
            --data-urlencode "message=${message}" \
            --data-urlencode "priority=${PUSHOVER_PRIORITY}" \
            "${PUSHOVER_API_URL}" >/dev/null 2>&1; then
            log_msg "action=notify result=transport_error"
            "${RM}" -f "${response_file}"
            return 1
        fi
    fi

    api_status="$("${PYTHON3}" -c '
import json
import sys
try:
    with open(sys.argv[1], "r", encoding="utf-8") as fh:
        data = json.load(fh)
    print(str(data.get("status", "")))
except Exception:
    print("")
' "${response_file}")"

    request_id="$("${PYTHON3}" -c '
import json
import sys
try:
    with open(sys.argv[1], "r", encoding="utf-8") as fh:
        data = json.load(fh)
    print(str(data.get("request", "")))
except Exception:
    print("")
' "${response_file}")"

    if [ "${api_status}" = "1" ]; then
        log_msg "action=notify result=success request=${request_id}"
        "${RM}" -f "${response_file}"
        return 0
    fi

    error_summary="$("${PYTHON3}" -c '
import json
import sys
try:
    with open(sys.argv[1], "r", encoding="utf-8") as fh:
        data = json.load(fh)
    errs = data.get("errors", [])
    if isinstance(errs, list):
        print("; ".join(str(x) for x in errs))
    else:
        print(str(errs))
except Exception:
    print("unable to parse pushover error response")
' "${response_file}")"

    log_msg "action=notify result=api_error request=${request_id} errors=${error_summary}"
    "${RM}" -f "${response_file}"
    return 1
}

#-------------------------------------------------------------------------------
# Build and send one boot-time not-up alert
#-------------------------------------------------------------------------------
notify_boot_problem() {
    gateway_name="$1"
    new_status="$2"

    new_status_text="$(format_status_for_alert "${new_status}")"

    title="${PUSHOVER_TITLE_PREFIX}: ${gateway_name}"
    message="Gateway ${gateway_name} is ${new_status_text} after boot delay on OPNsense."

    send_pushover_message "${title}" "${message}"
}

#-------------------------------------------------------------------------------
# Main entry point
#-------------------------------------------------------------------------------
main() {
    prepare_runtime
    validate_config

    log_msg "action=bootcheck status=starting delay=${BOOT_DELAY_SECONDS}"
    "${SLEEP}" "${BOOT_DELAY_SECONDS}"

    gateway_list_file="${STATE_DIR}/bootcheck-gateways.$$"
    list_gateway_statuses > "${gateway_list_file}"

    while IFS="$(printf '\t')" read -r gateway_name current_status; do
        [ -n "${gateway_name}" ] || continue

        last_status="$(get_last_status "${gateway_name}")"
        set_last_status "${gateway_name}" "${current_status}"

        case "${current_status}" in
            none)
                log_msg "gateway=${gateway_name} action=ignore reason=healthy status=${current_status}"
                ;;
            *)
                if [ "${last_status}" = "${current_status}" ] && [ -n "${last_status}" ]; then
                    log_msg "gateway=${gateway_name} action=ignore reason=already_notified status=${current_status}"
                else
                    log_msg "gateway=${gateway_name} action=alert reason=bootcheck status=${current_status}"
                    notify_boot_problem "${gateway_name}" "${current_status}" || true
                fi
                ;;
        esac
    done < "${gateway_list_file}"

    "${RM}" -f "${gateway_list_file}"
    log_msg "action=bootcheck status=complete"
}

main "$@"
